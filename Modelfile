# Shadow-Gemma Modelfile for shadow-code
# Optimized for code generation with tool calling
#
# Build: ollama create shadow-gemma -f Modelfile
# Run:   shadow-code  (or SHADOW_MODEL=shadow-gemma:latest shadow-code)

FROM gemma3:27b

# No SYSTEM here -- shadow-code injects its own system prompt via API.
# Having a Modelfile SYSTEM creates conflicts and confuses the model.

# --- Generation Parameters ---
# temperature 0.3: low randomness = consistent, complete code output
# top_k 40: focused token selection (not too greedy, not too random)
# top_p 0.9: nucleus sampling -- cuts off unlikely tokens
# repeat_penalty 1.1: prevents repetitive loops in long outputs
# num_predict 8192: allows long code output (default 2048 is too short)
# num_ctx 131072: full 128K context window

PARAMETER temperature 0.3
PARAMETER top_k 40
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.1
PARAMETER num_predict 8192
PARAMETER num_ctx 131072
PARAMETER stop <end_of_turn>
